# --- Meta Marketing (Graph) API ---
# Long-lived token (system user or page token) with scopes: ads_read, leads_retrieval
META_ACCESS_TOKEN=
# Ad account id, including the "act_" prefix
META_AD_ACCOUNT_ID=act_000000000000000
# Optional
META_GRAPH_VERSION=v21.0
META_ACCOUNT_NAME=Lançamento do Cliente
# Lead goal for the launch (used by the goal progress bar)
META_LEAD_GOAL=3000

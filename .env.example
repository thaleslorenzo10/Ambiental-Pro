# ============================================================
#  Dashboard de Captação — Imersão GIS (Ambiental Pro)
# ============================================================

# --- Meta Marketing (Graph) API ---
# Token de longa duração (system user) com escopo ads_read
META_ACCESS_TOKEN=
# ID numérico da conta de anúncios (pode ou não ter o prefixo act_)
META_AD_ACCOUNT_ID=673524229757641
# Substring presente no nome de TODAS as campanhas do lançamento
META_CAMPAIGN_TAG=[IMERSÃOGIS] [JUL26]
# Opcional
META_GRAPH_VERSION=v21.0

# --- Google Sheets (leads reais da página de captura) ---
# ID da planilha (o trecho entre /d/ e /edit)
GOOGLE_SHEET_ID=1tWeq8Lc8ZEjHtZyakgNbTqXSHmy7cMBLCyMyWkw1MoI
# Nome da aba com os leads (tem prioridade sobre o gid)
GOOGLE_SHEET_TAB=[IMERSÃO GIS][JUL26] Trackeamento de Lançamento
# Alternativa: gid numérico da aba
# GOOGLE_SHEET_GID=0
# Alternativa: URL completa "publicar na web" em CSV
# GOOGLE_SHEET_CSV_URL=
# A planilha precisa estar acessível (compartilhada "qualquer um com o link"
# ou publicada na web) para o app conseguir ler o CSV.

# Overrides opcionais de colunas (auto-detecta se omitido)
# SHEET_COL_NAME=Nome
# SHEET_COL_EMAIL=Email
# SHEET_COL_PHONE=Telefone
# SHEET_COL_DATE=Data
# SHEET_COL_SOURCE=utm_source
# SHEET_COL_MEDIUM=utm_medium
# SHEET_COL_CAMPAIGN=utm_campaign
# SHEET_COL_TERM=utm_term        # usado pra casar com o CONJUNTO (público) do Meta
# SHEET_COL_CONTENT=utm_content  # usado pra casar com o ANÚNCIO do Meta

# --- Classificação pago vs orgânico (ajuste se sua convenção for outra) ---
# LEAD_PAID_MEDIUMS=cpc,paid,ads,trafego
# LEAD_PAID_SOURCES=facebook_ads,instagram_ads
# LEAD_ORGANIC_SOURCES=whatsapp,email,bio,indicacao

# --- Metas do lançamento (concepção Imersão GIS JUL/26) ---
# Meta de leads
LAUNCH_LEAD_GOAL=8000
# Budget da CAPTAÇÃO (total do lançamento R$40k = captação R$32k + remarketing R$8k)
LAUNCH_BUDGET_TOTAL=32000
# CPL alvo
LAUNCH_CPL_TARGET=4
# Meta de vendas (fase de carrinho)
LAUNCH_SALES_GOAL=200
# Ticket médio do produto (PAP 5.0) — usado no cálculo de faturamento/ROAS
LAUNCH_TICKET=1500
# Investimento total do lançamento (captação R$32k + remarketing R$8k)
LAUNCH_TOTAL_INVESTMENT=40000
